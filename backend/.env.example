# 四时有序 (sishi-youxu) backend — example environment
# Copy to backend/.env and adjust values.
#
# 三端兼容说明：
#   - Web / Capacitor：所有标准 HTTP / WebSocket 用法
#   - 微信小程序：code2session 走 WX_APP_ID/SECRET；ws 走 ticket
#   - dev/test：WX_LOGIN_MOCK=true 时 code2session 走 mock

# ---- App ----
APP_NAME=sishi-youxu
APP_ENV=dev
APP_VERSION=0.2.0
DEBUG=true
API_V1_PREFIX=/api/v1

# 服务端时区（用于 /sync/status 校准；客户端按此渲染本地时间）
SERVER_TIMEZONE=Asia/Shanghai

# ---- Server ----
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ---- Database ----
DATABASE_URL=mysql+aiomysql://root:root@127.0.0.1:3306/sishi_youxu?charset=utf8mb4
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=sishiyouxu

# ---- JWT ----
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- WebSocket ticket ----
# 微信小程序无法在 ws 握手时设置 Header，必须走 ticket
WS_TICKET_EXPIRE_SECONDS=60
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_HEARTBEAT_TIMEOUT_SECONDS=90

# ---- WeChat mini-program ----
# Phase 3 实现 code2session 时填写；Phase 0 默认 mock
WX_APP_ID=
WX_APP_SECRET=
WX_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WX_LOGIN_MOCK=true

# ---- CORS ----
# 小程序不需要 CORS；Web 端按需放开。
# 注意：当 allow_origins 是 ["*"] 时 CORS_ALLOW_CREDENTIALS 必须为 false
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=text
